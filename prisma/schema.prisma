// Prisma schema — vocab-mvp
// 데이터 모델은 docs/spec-fixed.md / docs/prd.md 기준.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 단어장
model VocabSet {
  id         Int      @id @default(autoincrement())
  userId     Int?     @default(1) // 멀티유저 확장 예약 (무인증: 기본 1)
  name       String
  sourceFile String?
  totalWords Int      @default(0)
  createdAt  DateTime @default(now())
  words      Word[]

  @@map("vocab_set")
}

// 단어 (파싱 + AI 생성 결과 통합)
model Word {
  id         Int       @id @default(autoincrement())
  setId      Int
  kanji      String? // 한자 표기 (kana 단어는 null)
  reading    String // 후리가나 (소스 우선, 없으면 AI)
  meaningKo  String // 한국어 뜻
  synonyms   String? // JSON 문자열: ["温まる", ...]
  examples   String? // JSON 문자열: [{jp, reading, ko}, ...]
  posTag     String? // 품사 (P2)
  enrichedAt DateTime? // AI 생성 완료 시각
  set        VocabSet  @relation(fields: [setId], references: [id], onDelete: Cascade)
  srs        WordSrs?

  @@index([setId])
  @@map("word")
}

// SRS 학습 상태
model WordSrs {
  id             Int       @id @default(autoincrement())
  wordId         Int       @unique
  level          Int       @default(0) // 0~5
  nextReviewDate DateTime  @default(now())
  correctCount   Int       @default(0)
  wrongCount     Int       @default(0)
  lastReviewedAt DateTime?
  word           Word      @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@index([nextReviewDate])
  @@map("word_srs")
}

// 퀴즈 시도 로그 (통계·복습 근거)
model QuizAttempt {
  id         Int      @id @default(autoincrement())
  wordId     Int
  direction  String // "word_to_meaning" | "meaning_to_word"
  isCorrect  Boolean
  answeredAt DateTime @default(now())

  @@index([wordId])
  @@map("quiz_attempt")
}
